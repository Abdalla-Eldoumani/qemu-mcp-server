{
  "name": "qemu-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for AI agent control of QEMU virtual machines",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "qemu-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run tests/unit",
    "test:all": "vitest run",
    "test:watch": "vitest watch tests/unit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "qemu",
    "virtual-machine",
    "ai-agent",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
